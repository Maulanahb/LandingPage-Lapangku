            className="lg:hidden p-2 rounded-full bg-white/80 border border-slate-200/70 text-slate-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 hover:bg-slate-50 transition-all active:scale-95"
          >
            {isMobileMenuOpen ? <X className="w-5 h-5" /> : <Menu className="w-5 h-5" />}
