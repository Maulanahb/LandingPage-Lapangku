                                onClick={() => selectCustomerScreen(1)}
                              >
                                <div className="bg-white/10 p-4 rounded-3xl backdrop-blur-md border border-white/20 mb-4 animate-pulse">
                                  <Smartphone className="w-10 h-10 text-white" />
